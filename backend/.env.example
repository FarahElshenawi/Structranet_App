# ────────────────────────────────────────────────────────────
# StructuraNet Backend Environment
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO=mongodb://localhost:27017/structuranet

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=replace_me_with_random_hex
JWT_REFRESH_SECRET=replace_me_with_random_hex

# Token Expiries
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# LLM (OpenRouter)
ROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openrouter/owl-alpha
AI_MAX_TOKENS=16384

# AI Engine Bridge
WRAPPER_PATH=../ai-engine/wrapper.py
PYTHON_BIN=python
OUTPUT_DIR=./output

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
