# ═══════════════════════════════════════════════════════════════════════
# StructuraNet AI — Express Backend Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Server ──────────────────────────────────────────────────────────────
PORT=3000

# ── JWT Authentication ─────────────────────────────────────────────────
# Change this to a strong random string in production!
JWT_SECRET=dev-secret-key

# ── MongoDB ────────────────────────────────────────────────────────────
# Full MongoDB URI. If empty or localhost, falls back to in-memory MongoDB.
# Examples:
#   MONGO=mongodb://localhost:27017/structuranet
#   MONGO=mongodb+srv://user:pass@cluster.mongodb.net/structuranet
MONGO=

# ── FastAPI AI Engine ──────────────────────────────────────────────────
# URL of the FastAPI AI engine (the Python backend)
FASTAPI_URL=http://localhost:8000
